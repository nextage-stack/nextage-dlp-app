# Copy to terraform.tfvars (git-ignored) and fill in real values.

# REQUIRED — Azure subscription + tenant
subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "11111111-1111-1111-1111-111111111111"

# REQUIRED — Stable add-in GUID. Generate ONCE via: uuidgen
# DO NOT regenerate on subsequent deploys, or every existing install treats
# the add-in as new and the user re-prompts for consent.
manifest_guid = "22222222-2222-2222-2222-222222222222"

# REQUIRED — Long random secret used to hash PII in audit entries.
# Generate via: openssl rand -hex 32
# Rotate independently from app deploys (rotating invalidates historical hashes).
audit_hmac_key = "REPLACE-WITH-OPENSSL-RAND-HEX-32-OUTPUT"

# Optional — overrides for defaults
location            = "westeurope"
resource_group_name = "rg-nextage-dlp-prod"
name_prefix         = "nextage-dlp"

# Optional — public IPs allowed direct Cosmos access (admin break-glass).
# Function App outbound IPs are added automatically.
# cosmos_admin_ips = ["203.0.113.5/32"]

# Optional — custom tags
tags = {
  Project     = "Nextage-DLP"
  Environment = "test"
  Owner       = "mor.mordechai@nextage.co.il"
  CostCenter  = "IT"
  ManagedBy   = "terraform"
}
