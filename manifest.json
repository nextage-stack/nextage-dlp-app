{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "3.0.0",
  "id": "${MANIFEST_GUID}",
  "name": {
    "short": "Nextage DLP",
    "full": "Nextage DLP Email Guard"
  },
  "description": {
    "short": "DLP protection for outgoing emails",
    "full": "Prevents data loss by validating outgoing emails before send (encryption, filename, subject + domain)."
  },
  "icons": {
    "outline": "assets/icon-32.png",
    "color": "assets/icon-80.png"
  },
  "accentColor": "#1F5C99",
  "developer": {
    "name": "Nextage IT",
    "websiteUrl": "https://nextage.co.il",
    "privacyUrl": "https://nextage.co.il/privacy",
    "termsOfUseUrl": "https://nextage.co.il/terms"
  },
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        { "name": "MailboxItem.ReadWrite.User", "type": "Delegated" },
        { "name": "Mailbox.ReadWrite.User", "type": "Delegated" }
      ]
    }
  },
  "validDomains": [
    "${SWA_HOSTNAME}",
    "${FUNCTIONS_HOSTNAME}"
  ],
  "webApplicationInfo": {
    "id": "${ENTRA_APP_CLIENT_ID}",
    "resource": "api://${SWA_HOSTNAME}/${ENTRA_APP_CLIENT_ID}"
  },
  "extensions": [
    {
      "requirements": {
        "capabilities": [{ "name": "Mailbox", "minVersion": "1.14" }]
      },
      "runtimes": [
        {
          "id": "shared-runtime",
          "type": "general",
          "code": {
            "page": "https://${SWA_HOSTNAME}/taskpane.html",
            "script": "https://${SWA_HOSTNAME}/commands.js"
          },
          "lifetime": "short",
          "actions": [
            {
              "id": "onMessageSend",
              "type": "executeFunction",
              "displayName": "DLP Check"
            },
            {
              "id": "openTaskPane",
              "type": "openPage",
              "view": "dlp-pane"
            }
          ]
        }
      ],
      "autoRunEvents": [
        {
          "events": [{ "type": "messageSending", "actionId": "onMessageSend" }],
          "requirements": {
            "capabilities": [{ "name": "Mailbox", "minVersion": "1.14" }]
          }
        }
      ],
      "ribbons": [
        {
          "contexts": ["mailCompose"],
          "tabs": [
            {
              "builtInTabId": "TabDefault",
              "groups": [
                {
                  "id": "dlp-group",
                  "label": "DLP Guard",
                  "icons": [{ "size": 32, "file": "assets/icon-32.png" }],
                  "controls": [
                    {
                      "id": "dlp-button",
                      "type": "button",
                      "label": "Check DLP",
                      "icons": [{ "size": 32, "file": "assets/icon-32.png" }],
                      "supertip": {
                        "title": "DLP Check",
                        "description": "Validate email before sending"
                      },
                      "actionId": "openTaskPane"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
