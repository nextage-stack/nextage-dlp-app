<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
           xsi:type="MailApp">

  <Id>${MANIFEST_GUID}</Id>
  <Version>3.0.0.0</Version>
  <ProviderName>Nextage Ltd</ProviderName>
  <DefaultLocale>he-IL</DefaultLocale>
  <DisplayName DefaultValue="Nextage DLP Guard"/>
  <Description DefaultValue="הגנה אוטומטית מפני דליפת מידע במיילים יוצאים"/>
  <IconUrl DefaultValue="https://${SWA_HOSTNAME}/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://${SWA_HOSTNAME}/assets/icon-80.png"/>
  <SupportUrl DefaultValue="https://nextage.co.il/support"/>

  <AppDomains>
    <AppDomain>https://${FUNCTIONS_HOSTNAME}</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.14"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://${SWA_HOSTNAME}/taskpane.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_1">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.14">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <Runtimes>
          <Runtime resid="WebViewRuntime.Url" lifetime="short">
            <Override type="javascript" resid="JsRuntime.Url"/>
          </Runtime>
        </Runtimes>

        <DesktopFormFactor>
          <FunctionFile resid="JsRuntime.Url"/>

          <!-- Manual TaskPane (ribbon button) -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeDLPGroup">
                <Label resid="dlpGroupLabel.label"/>
                <Control xsi:type="Button" id="msgComposeDLPButton">
                  <Label resid="dlpButton.label"/>
                  <Supertip>
                    <Title resid="dlpButton.title"/>
                    <Description resid="dlpButton.description"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskPaneUrl.url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- OnMessageSend - active blocking -->
          <ExtensionPoint xsi:type="LaunchEvent">
            <LaunchEvents>
              <LaunchEvent Type="OnMessageSend" FunctionName="onMessageSend" SendMode="PromptUser"/>
            </LaunchEvents>
            <SourceLocation resid="JsRuntime.Url"/>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://${SWA_HOSTNAME}/assets/icon-16.png"/>
        <bt:Image id="icon32" DefaultValue="https://${SWA_HOSTNAME}/assets/icon-32.png"/>
        <bt:Image id="icon80" DefaultValue="https://${SWA_HOSTNAME}/assets/icon-80.png"/>
      </bt:Images>

      <bt:Urls>
        <bt:Url id="JsRuntime.Url" DefaultValue="https://${SWA_HOSTNAME}/commands.js"/>
        <bt:Url id="WebViewRuntime.Url" DefaultValue="https://${SWA_HOSTNAME}/commands.html"/>
        <bt:Url id="taskPaneUrl.url" DefaultValue="https://${SWA_HOSTNAME}/taskpane.html"/>
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="dlpGroupLabel.label" DefaultValue="DLP"/>
        <bt:String id="dlpButton.label" DefaultValue="בדוק DLP"/>
        <bt:String id="dlpButton.title" DefaultValue="בדיקת DLP - Nextage"/>
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="dlpButton.description"
                   DefaultValue="בדיקת הצפנה, שמות קבצים ונושא המייל לפני שליחה"/>
      </bt:LongStrings>
    </Resources>

    <WebApplicationInfo>
      <Id>${ENTRA_APP_CLIENT_ID}</Id>
      <Resource>api://${SWA_HOSTNAME}/${ENTRA_APP_CLIENT_ID}</Resource>
      <Scopes>
        <Scope>access_as_user</Scope>
        <Scope>profile</Scope>
        <Scope>openid</Scope>
      </Scopes>
    </WebApplicationInfo>

  </VersionOverrides>

</OfficeApp>
