{
  "name": "nextage-dlp-addin",
  "version": "3.0.0",
  "description": "Nextage DLP Outlook Add-in - Production architecture (v3)",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production && npm run build:manifests",
    "build:dev": "webpack --mode development",
    "build:manifests": "ts-node --transpile-only scripts/build-manifests.ts",
    "watch": "webpack --mode development --watch",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "validate-manifest": "office-addin-manifest validate dist/manifest.json",
    "validate-manifest-xml": "office-addin-manifest validate dist/manifest-legacy.xml",
    "setup:cosmos": "ts-node scripts/setup-dev-cosmos.ts",
    "seed:cosmos": "ts-node scripts/seed-dev-data.ts"
  },
  "keywords": ["dlp", "outlook", "office-addin", "nextage", "azure", "cosmos-db"],
  "author": "Nextage IT",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/office-js": "^1.0.589",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.57.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "office-addin-manifest": "^1.13.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {}
}
