{
  "name": "nextage-dlp-addin-local",
  "version": "7.0.0",
  "description": "Nextage DLP Outlook Add-in - LOCAL dev build (serves from https://localhost:3000)",
  "private": true,
  "type": "module",
  "scripts": {
    "setup-certs": "npx --yes office-addin-dev-certs install",
    "start": "node node_modules/webpack/bin/webpack.js serve --mode development",
    "build": "node node_modules/webpack/bin/webpack.js --mode production && npm run build:manifests",
    "build:dev": "node node_modules/webpack/bin/webpack.js --mode development",
    "build:manifests": "node scripts/build-manifests.mjs",
    "watch": "node node_modules/webpack/bin/webpack.js --mode development --watch",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "validate-manifest": "node node_modules/office-addin-manifest/cli.js validate dist/manifest.json",
    "validate-manifest-xml": "node node_modules/office-addin-manifest/cli.js validate manifest.xml",
    "setup:cosmos": "ts-node scripts/setup-dev-cosmos.ts",
    "seed:cosmos": "ts-node scripts/seed-dev-data.ts"
  },
  "keywords": [
    "dlp",
    "outlook",
    "office-addin",
    "nextage",
    "azure",
    "cosmos-db"
  ],
  "author": "Nextage IT",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/office-js": "^1.0.589",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.57.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "office-addin-manifest": "^1.13.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.21.0"
  }
}
